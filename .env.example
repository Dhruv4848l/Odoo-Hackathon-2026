# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# REPLACE '<username>', '<password>', and '<database_name>' with your Atlas credentials.
# CRITICAL: Each developer must append their custom suffix to database name to avoid data collision!
# Examples: ecosphere-dev-a, ecosphere-dev-b, ecosphere-dev-c, ecosphere-dev-d
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxxx.mongodb.net/ecosphere-dev-a?retryWrites=true&w=majority

# Authentication Configuration
JWT_SECRET=supersecretjwtkeyforhackathon12345
JWT_EXPIRE=24h

# Client URL (For CORS configuration)
CLIENT_URL=http://localhost:5173